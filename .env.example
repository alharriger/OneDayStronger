# ─────────────────────────────────────────────────────────────────────────────
# One Day Stronger — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# Variable scopes:
#   EXPO_PUBLIC_*  — bundled into the client app; safe to expose (not secrets)
#   APP_ENV        — read at build time; controls model selection and mocking
#
# Supabase Edge Function secrets are NOT set here. See the section at the
# bottom of this file for the CLI commands to set them.
# ─────────────────────────────────────────────────────────────────────────────


# ── Environment ───────────────────────────────────────────────────────────────
# "dev" uses claude-haiku-4-5-20251001 or mocked LLM responses.
# "prod" uses claude-sonnet-4-6 and live API calls.
APP_ENV=dev


# ── Supabase (client) ─────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
# The anon key is safe to expose — RLS enforces data access.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key


# ── Cloudflare R2 (client-facing config only) ─────────────────────────────────
# The public base URL for serving exercise demo videos (read-only).
# Credentials for upload/presign are edge function secrets — see below.
EXPO_PUBLIC_R2_PUBLIC_URL=https://your-r2-custom-domain-or-public-bucket-url


# ─────────────────────────────────────────────────────────────────────────────
# Supabase Edge Function Secrets
# ─────────────────────────────────────────────────────────────────────────────
# These values are NEVER placed in this file. They are set via the Supabase CLI
# and stored encrypted on Supabase's servers. The edge functions read them at
# runtime via Deno.env.get().
#
# Run the following commands to configure your edge function secrets:
#
#   supabase secrets set CLAUDE_API_KEY=sk-ant-...
#   supabase secrets set CLOUDFLARE_R2_ACCOUNT_ID=...
#   supabase secrets set CLOUDFLARE_R2_ACCESS_KEY_ID=...
#   supabase secrets set CLOUDFLARE_R2_SECRET_ACCESS_KEY=...
#   supabase secrets set CLOUDFLARE_R2_BUCKET_NAME=one-day-stronger
#
# To verify secrets are set:
#   supabase secrets list
#
# Required secrets:
#   CLAUDE_API_KEY                  — Anthropic API key (sk-ant-...)
#   CLOUDFLARE_R2_ACCOUNT_ID        — Found in R2 dashboard → Account ID
#   CLOUDFLARE_R2_ACCESS_KEY_ID     — R2 API token access key
#   CLOUDFLARE_R2_SECRET_ACCESS_KEY — R2 API token secret key
#   CLOUDFLARE_R2_BUCKET_NAME       — Name of your R2 bucket
# ─────────────────────────────────────────────────────────────────────────────
